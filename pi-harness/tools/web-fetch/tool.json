{
  "name": "web_fetch",
  "version": 1,
  "description": "Fetch public HTTP(S) content. Private and loopback networks are blocked.",
  "risk": "network",
  "timeoutMs": 20000,
  "handler": "builtin:web-fetch",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["url"],
    "properties": {
      "url": { "type": "string" },
      "method": { "type": "string", "enum": ["GET", "POST"] },
      "headers": { "type": "object", "additionalProperties": { "type": "string" } },
      "body": { "type": "string" },
      "timeoutMs": { "type": "integer", "minimum": 100, "maximum": 60000 }
    }
  }
}
