{
  "name": "system_command",
  "version": 1,
  "description": "Run a program with arguments inside the Stock Harness workspace. Shell syntax is not interpreted.",
  "risk": "execute",
  "timeoutMs": 30000,
  "handler": "builtin:system-command",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["command"],
    "properties": {
      "command": { "type": "string" },
      "args": { "type": "array", "items": { "type": "string" } },
      "cwd": { "type": "string" },
      "timeoutMs": { "type": "integer", "minimum": 100, "maximum": 120000 }
    }
  }
}
